#!/usr/bin/env bash
# ==============================================================================
# nvsx — launcher for NVSentinel eXtensions
# ==============================================================================
# Clone-and-run: creates a local .venv on first run, then execs the CLI.
# Also installable via `pip install nvsx` (see pyproject.toml), which gives
# you the same `nvsx` command on your PATH without this launcher.
# ==============================================================================
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
VENV="$HERE/.venv"
PYSRC="$HERE/src"
DEPS=(typer "rich>=13.7" "pydantic>=2.5" "pyyaml>=6.0" "pymongo>=4.6")

if [[ ! -x "$VENV/bin/python" ]]; then
    echo "[nvsx] First-run setup: creating .venv/ ..." >&2
    if command -v uv >/dev/null 2>&1; then
        uv venv -q "$VENV" >&2
        "$VENV/bin/python" -m pip install -q --upgrade pip >&2
        uv pip install -q --python "$VENV/bin/python" "${DEPS[@]}" >&2
    else
        python3 -m venv "$VENV" >&2
        "$VENV/bin/pip" install -q --upgrade pip >&2
        "$VENV/bin/pip" install -q "${DEPS[@]}" >&2
    fi
    echo "[nvsx] Ready." >&2
fi

export PYTHONPATH="$PYSRC${PYTHONPATH:+:$PYTHONPATH}"
exec "$VENV/bin/python" -m nvsx "$@"
